// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: bookings
// Document ID: {bookingId}
// Fields:
//   - name: string (required)
//   - contact: string (required)
//   - date: string (required, format: YYYY-MM-DD)
//   - message: string (optional)
//   - type: string (required, enum: ['event', 'hall'])
//   - status: string (required, enum: ['pending', 'confirmed', 'cancelled'])
//   - createdAt: timestamp (required)
//
// Collection: memberRequests
// Document ID: {requestId}
// Fields:
//   - name: string (required)
//   - contact: string (required)
//   - status: string (required, enum: ['pending', 'processed'])
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "fonsecaajoel@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['name', 'contact', 'date', 'type', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.contact is string && data.contact.size() > 0 && data.contact.size() < 50 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.type in ['event', 'hall'] &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             data.createdAt is timestamp;
    }

    function isValidMemberRequest(data) {
      return data.keys().hasAll(['name', 'contact', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.contact is string && data.contact.size() > 0 && data.contact.size() < 50 &&
             data.status in ['pending', 'processed'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /bookings/{bookingId} {
      // Anyone can create a booking request
      allow create: if isValidBooking(request.resource.data) && request.resource.data.status == 'pending';
      
      // Only admin can read, update or delete bookings
      allow read, update, delete: if isAdmin();
    }

    match /memberRequests/{requestId} {
      // Anyone can request to be a member
      allow create: if isValidMemberRequest(request.resource.data) && request.resource.data.status == 'pending';
      
      // Only admin can read, update or delete member requests
      allow read, update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
